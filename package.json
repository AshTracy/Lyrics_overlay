{
  "name": "lyrics-overlay",
  "version": "2.0.0",
  "description": "Always-on-top lyrics overlay for desktop",
  "author": "Ashley",
  "main": "src/main/index.js",
  "scripts": {
    "start":         "electron src/main/index.js",
    "dev":           "electron src/main/index.js --dev",
    "build":         "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --win",
    "publish":       "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --win --publish always",
    "publish:draft": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --win --publish onTagOrDraft"
  },
  "dependencies": {
    "music-metadata": "^10.0.0"
  },
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.0.0",
    "cross-env":        "^7.0.3"
  },
  "build": {
    "appId":       "com.yourname.lyrics-overlay",
    "productName": "Lyrics Overlay",
    "copyright":   "MIT",
    "directories": {
      "output":         "dist",
      "buildResources": "build-assets"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/modules/smtc_bridge.py",
        "to":   "smtc_bridge.py"
      },
      {
        "from": "bundled-python/",
        "to":   "python/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build-assets/icon.ico",
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick":                          false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut":             true,
      "createStartMenuShortcut":           true,
      "shortcutName":                      "Lyrics Overlay",
      "installerIcon":                     "build-assets/icon.ico",
      "uninstallerIcon":                   "build-assets/icon.ico",
      "installerHeaderIcon":               "build-assets/icon.ico"
    },
    "mac": {
      "category": "public.app-category.music",
      "icon":     "build-assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon":   "build-assets/icon.png"
    },
    "electronVersion": "28.0.0"
  }
}